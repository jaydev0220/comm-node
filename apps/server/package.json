{
	"name": "@apps/server",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "tsx watch --env-file=.env.development src/index.ts",
		"build": "tsc",
		"start": "node build/index.js",
		"lint": "eslint .",
		"format": "prettier --write --ignore-path ../../.prettierignore .",
		"type-check": "tsc --noEmit",
		"db:generate": "prisma generate",
		"db:migrate:dev": "prisma migrate dev",
		"db:migrate:deploy": "prisma migrate deploy",
		"db:studio": "prisma studio",
		"db:push": "prisma db push",
		"db:seed": "prisma db seed"
	},
	"dependencies": {
		"@prisma/adapter-pg": "catalog:server",
		"@prisma/client": "catalog:server",
		"cors": "catalog:server",
		"express": "catalog:server",
		"helmet": "catalog:server",
		"pg": "catalog:server",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@eslint/js": "catalog:server",
		"@packages/prettier-config": "workspace:*",
		"@types/cors": "catalog:server",
		"@types/express": "catalog:server",
		"@types/node": "catalog:",
		"@types/pg": "catalog:server",
		"eslint": "catalog:server",
		"globals": "catalog:server",
		"prettier": "catalog:",
		"prisma": "catalog:server",
		"tsx": "catalog:server",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:server"
	},
	"prettier": "@packages/prettier-config"
}
